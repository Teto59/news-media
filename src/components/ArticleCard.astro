---
import type { CollectionEntry } from "astro:content";
import TagChips from "./TagChips.astro";
import { formatDate } from "../lib/articles";

interface Props {
  article: CollectionEntry<"articles">;
  index?: number;
  featured?: boolean;
}

const { article, index = 0, featured = false } = Astro.props;
// frontmatterのthumbが指定されていればそれを、なければ自動生成SVGを使う
const thumbSrc = article.data.thumb ?? `/thumbs/${article.id}.svg`;
---

<div class={`card ${featured ? "card-featured" : ""}`} style={`animation-delay: ${index * 40}ms`}>
  <img
    class="card-thumb"
    src={thumbSrc}
    alt=""
    width={featured ? 1200 : 800}
    height={featured ? 675 : 450}
    loading={featured ? "eager" : "lazy"}
  />
  <div class="card-body">
    {featured && <p class="card-label font-mono">最新</p>}
    <TagChips tags={article.data.tags} />
    <h2 class="card-title font-mincho">
      <a class="card-title-link" href={`/articles/${article.id}/`}>{article.data.title}</a>
    </h2>
    <p class="card-lead">{article.data.lead}</p>
    <p class="card-date font-mono">{formatDate(article.data.pubDate)}</p>
  </div>
</div>

<style>
  .card {
    position: relative;
    display: block;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      border-color 160ms ease-out,
      transform 160ms ease-out;
    animation: card-in 420ms ease-out both;
  }

  .card:hover {
    border-color: var(--ai);
    transform: translateY(-2px);
  }

  /* カード全体をクリック可能にする(タグチップは個別リンクとして上に浮かせる) */
  .card-title-link {
    color: inherit;
    text-decoration: none;
  }

  .card-title-link::after {
    content: "";
    position: absolute;
    inset: 0;
  }

  .card-thumb {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
  }

  .card-body {
    padding: 1rem 1.1rem 1.25rem;
  }

  .card-title {
    font-size: 1.1rem;
    line-height: 1.5;
    margin: 0.6rem 0 0.5rem;
    color: var(--ink);
  }

  .card-lead {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0 0 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 日付行の上に細罫を入れて紙面の「段」の区切りを出す */
  .card-date {
    font-size: 0.75rem;
    color: var(--ink-2);
    margin: 0;
    border-top: 1px solid var(--line);
    padding-top: 0.55rem;
  }

  /* 最新記事の朱ラベル(朱の短い罫+文字) */
  .card-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--shu);
    margin: 0 0 0.7rem;
  }

  .card-label::before {
    content: "";
    width: 1.4rem;
    height: 2px;
    background: var(--shu);
  }

  /* 最新1本の大型カード: サムネと本文を横並びにする */
  .card-featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
  }

  /* サムネは常に16:9のまま全体を表示する(クロップしない)。
     本文がサムネより縦長の場合はサムネを上下中央に置く */
  .card-featured .card-thumb {
    aspect-ratio: 16 / 9;
    height: auto;
    align-self: center;
    border-bottom: none;
  }

  .card-featured .card-body {
    border-left: 1px solid var(--line);
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-featured .card-title {
    font-size: clamp(1.3rem, 2.6vw, 1.9rem);
    line-height: 1.4;
    margin-top: 0.8rem;
  }

  .card-featured .card-lead {
    font-size: 1rem;
    -webkit-line-clamp: 3;
  }

  @media (max-width: 720px) {
    .card-featured {
      grid-template-columns: 1fr;
    }

    .card-featured .card-thumb {
      align-self: stretch;
      border-bottom: 1px solid var(--line);
    }

    .card-featured .card-body {
      border-left: none;
    }
  }

  @keyframes card-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
