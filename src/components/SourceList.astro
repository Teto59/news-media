---
import { formatDate } from "../lib/articles";

interface Source {
  name: string;
  url: string;
  publisher?: string;
  accessed: Date;
}

interface Props {
  sources: Source[];
}

const { sources } = Astro.props;
---

<section class="source-list" aria-label="出典">
  <h2 class="section-heading font-mincho">出典</h2>
  <ol>
    {
      sources.map((source, i) => (
        <li id={`source-${i + 1}`}>
          <span class="source-num font-mono">[{i + 1}]</span>
          <a href={source.url} target="_blank" rel="noopener noreferrer">
            {source.name}
          </a>
          {source.publisher && <span class="source-meta"> / {source.publisher}</span>}
          <span class="source-meta font-mono"> / 参照日: {formatDate(source.accessed)}</span>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .source-list {
    margin: 2.5rem 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .section-heading {
    font-size: 1.05rem;
    margin: 0 0 0.9rem;
  }

  ol {
    margin: 0;
    padding-left: 0;
    list-style: none;
    counter-reset: none;
  }

  li {
    margin: 0.6rem 0;
    line-height: 1.7;
    font-size: 0.9rem;
  }

  .source-num {
    color: var(--ink-2);
    margin-right: 0.3rem;
  }

  .source-meta {
    color: var(--ink-2);
    font-size: 0.82rem;
  }
</style>
