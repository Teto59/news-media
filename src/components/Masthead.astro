---
import ThemeToggle from "./ThemeToggle.astro";
import { SITE_NAME } from "../consts";

const today = new Date().toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<header class="masthead">
  <div class="masthead-row">
    <a href="/" class="logotype font-mincho">
      <span class="hanko font-mincho" aria-hidden="true">紀</span>
      {SITE_NAME}
    </a>
    <span class="today font-mono">{today}</span>
  </div>
  <div class="masthead-actions">
    <a href="/archive" class="search-link font-mono">一覧</a>
    <a href="/search" class="search-link font-mono">検索</a>
    <ThemeToggle />
  </div>
</header>

<style>
  /* 題字の下は新聞らしい二重罫(墨の太罫+細罫) */
  .masthead {
    position: relative;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 1rem;
    border-bottom: 2px solid var(--ink);
  }

  .masthead::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 1px;
    background: var(--line);
  }

  /* faviconと揃えた朱の角印。題字の左に添える */
  .hanko {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15em;
    height: 1.15em;
    background: var(--shu);
    color: var(--paper);
    font-size: 0.55em;
    font-weight: 700;
    border-radius: var(--radius);
    transform: translateY(-0.12em);
  }

  .masthead-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .logotype {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .today {
    color: var(--ink-2);
    font-size: 0.85rem;
  }

  .masthead-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .search-link {
    color: var(--ink-2);
    text-decoration: none;
    font-size: 0.85rem;
    border-bottom: 1px solid transparent;
    transition: all 160ms ease-out;
  }

  .search-link:hover {
    color: var(--ai);
    border-bottom-color: var(--ai);
  }
</style>
