---
import ThemeToggle from "./ThemeToggle.astro";
import { SITE_NAME } from "../consts";

const today = new Date().toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<header class="masthead">
  <div class="masthead-row">
    <a href="/" class="logotype font-mincho">{SITE_NAME}</a>
    <span class="today font-mono">{today}</span>
  </div>
  <div class="masthead-actions">
    <a href="/search" class="search-link font-mono">検索</a>
    <ThemeToggle />
  </div>
</header>

<style>
  .masthead {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 1rem;
    border-bottom: 1px solid var(--line);
  }

  .masthead-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .logotype {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .today {
    color: var(--ink-2);
    font-size: 0.85rem;
  }

  .masthead-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .search-link {
    color: var(--ink-2);
    text-decoration: none;
    font-size: 0.85rem;
    border-bottom: 1px solid transparent;
    transition: all 160ms ease-out;
  }

  .search-link:hover {
    color: var(--ai);
    border-bottom-color: var(--ai);
  }
</style>
