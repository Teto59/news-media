---
import Base from "../layouts/Base.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getPublishedArticles } from "../lib/articles";

const articles = await getPublishedArticles();
const [featured, ...rest] = articles;
---

<Base>
  <div class="top-wrap">
    {
      featured ? (
        <>
          <div class="featured-slot">
            <ArticleCard article={featured} featured index={0} />
          </div>
          {rest.length > 0 && (
            <>
              <h2 class="section-head font-mincho">記事一覧</h2>
              <div class="card-grid">
                {rest.map((article, i) => (
                  <ArticleCard article={article} index={i + 1} />
                ))}
              </div>
            </>
          )}
        </>
      ) : (
        <p class="empty-state">まだ公開記事がありません。近日公開予定です。</p>
      )
    }
  </div>
</Base>

<style>
  .top-wrap {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .featured-slot {
    margin-bottom: 2.25rem;
  }

  /* 新聞の段見出し: 藍の角マーク+明朝+細罫 */
  .section-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.5rem;
    margin: 0 0 1.25rem;
  }

  .section-head::before {
    content: "";
    width: 0.55em;
    height: 0.55em;
    background: var(--ai);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-state {
    color: var(--ink-2);
    text-align: center;
    padding: 4rem 1rem;
  }
</style>
